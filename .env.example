# ============================================================
# .env.example — copy to .env if you wire a backend feature.
# The site as shipped is 100% static — none of these are needed.
# The .env file is git-ignored. NEVER commit real secrets.
# ============================================================

# --- Contact form (only if you add one) ---------------------
# Use Formspree — its endpoint URL is safe to expose in the client.
# VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/yourFormId

# --- Analytics (optional, note it in README) ----------------
# VITE_PLAUSIBLE_DOMAIN=marcolo.example.com

# --- Never prefix server secrets with VITE_ ----------------
# VITE_ prefix exposes values to the browser bundle.
# Server-only keys belong in a backend/.env, not here.
